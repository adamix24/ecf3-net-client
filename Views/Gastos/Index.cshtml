@model FacturasWeb.Services.GastosListado
@{
    ViewData["Title"] = "Gastos";
    var f = ViewBag.Filtros as FacturasWeb.Services.GastoFiltros ?? new FacturasWeb.Services.GastoFiltros();
    var limit = f.Limit ?? 50;
    var offset = f.Offset ?? 0;
    var haySiguiente = offset + Model.Gastos.Count < Model.Total;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Gastos <small class="text-muted">(@Model.Total total)</small></h2>
    <a class="btn btn-primary" asp-action="Create">+ Registrar gasto</a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<partial name="_ApiLogModal" />

<form method="get" class="row g-2 mb-3 align-items-end">
    <div class="col-md-2">
        <label class="form-label small mb-0">RNC proveedor</label>
        <input type="text" name="rncEmisor" value="@f.RncEmisor" class="form-control form-control-sm" />
    </div>
    <div class="col-md-2">
        <label class="form-label small mb-0">Tipo</label>
        <select name="tipoEcf" class="form-select form-select-sm">
            <option value="">Todos</option>
            <option value="31" selected="@(f.TipoEcf=="31")">31</option>
            <option value="32" selected="@(f.TipoEcf=="32")">32</option>
            <option value="41" selected="@(f.TipoEcf=="41")">41</option>
            <option value="43" selected="@(f.TipoEcf=="43")">43</option>
            <option value="44" selected="@(f.TipoEcf=="44")">44</option>
            <option value="45" selected="@(f.TipoEcf=="45")">45</option>
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label small mb-0">Desde</label>
        <input type="date" name="desde" value="@f.Desde" class="form-control form-control-sm" />
    </div>
    <div class="col-md-2">
        <label class="form-label small mb-0">Hasta</label>
        <input type="date" name="hasta" value="@f.Hasta" class="form-control form-control-sm" />
    </div>
    <div class="col-md-2">
        <label class="form-label small mb-0">Límite</label>
        <input type="number" name="limit" value="@limit" min="1" max="200" class="form-control form-control-sm" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-sm btn-outline-primary w-100">Filtrar</button>
    </div>
</form>

@if (!Model.Gastos.Any())
{
    <div class="alert alert-info">No hay gastos registrados @((f.RncEmisor??f.TipoEcf??f.Desde??f.Hasta)!=null ? "con esos filtros" : "todavía").</div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Fecha</th>
                <th>RNC proveedor</th>
                <th>Razón social</th>
                <th>NCF</th>
                <th>Tipo</th>
                <th>Estado</th>
                <th class="text-end">Total</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var g in Model.Gastos)
        {
            <tr>
                <td>@g.Id</td>
                <td>@g.FechaEmision</td>
                <td>@g.RncEmisor</td>
                <td>@g.RazonSocialEmisor</td>
                <td><code>@g.Ncf</code></td>
                <td>@g.TipoEcf</td>
                <td>@g.Estado</td>
                <td class="text-end">@g.Total.ToString("N2")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@g.Id">Ver</a>
                    <form asp-action="Eliminar" asp-route-id="@g.Id" method="post" class="d-inline"
                          onsubmit="return confirm('¿Eliminar el gasto @g.Id?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">×</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <nav class="d-flex justify-content-between">
        <div class="text-muted small">Mostrando @(offset + 1)–@(offset + Model.Gastos.Count) de @Model.Total</div>
        <div class="btn-group btn-group-sm">
            @if (offset > 0)
            {
                var prevOff = Math.Max(0, offset - limit);
                <a class="btn btn-outline-secondary" href="?rncEmisor=@f.RncEmisor&tipoEcf=@f.TipoEcf&desde=@f.Desde&hasta=@f.Hasta&limit=@limit&offset=@prevOff">← Anterior</a>
            }
            @if (haySiguiente)
            {
                var nextOff = offset + limit;
                <a class="btn btn-outline-secondary" href="?rncEmisor=@f.RncEmisor&tipoEcf=@f.TipoEcf&desde=@f.Desde&hasta=@f.Hasta&limit=@limit&offset=@nextOff">Siguiente →</a>
            }
        </div>
    </nav>
}
