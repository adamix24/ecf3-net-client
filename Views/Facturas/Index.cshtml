@model IEnumerable<FacturasWeb.Models.Factura>
@{
    ViewData["Title"] = "Facturas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Facturas</h2>
    <a class="btn btn-primary" asp-action="Create">+ Nueva factura</a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<p class="text-muted small">Carpeta de almacenamiento: <code>@ViewBag.Carpeta</code></p>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay facturas todavía. Crea la primera.</div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Número</th>
                <th>Fecha</th>
                <th>Tipo</th>
                <th>Cliente</th>
                <th>RNC</th>
                <th>NCF</th>
                <th>Estado DGII</th>
                <th class="text-end">Total</th>
                <th class="text-end" style="width:320px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var f in Model)
        {
            <tr>
                <td>
                    @f.Numero
                    @if (f.TipoEcf == "34")
                    {
                        <span class="badge bg-warning text-dark ms-1" title="Nota de crédito">NC</span>
                    }
                </td>
                <td>@f.Fecha.ToString("yyyy-MM-dd")</td>
                <td>@f.TipoEcf</td>
                <td>@f.Cliente</td>
                <td>@f.Rnc</td>
                <td><code>@f.Ncf</code></td>
                <td>
                    @if (f.EstaFirmada)
                    {
                        <span class="badge bg-success">@f.EstadoDgii</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">sin firmar</span>
                    }
                </td>
                <td class="text-end">@f.Total.ToString("N2")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@f.Id">Ver</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Print" asp-route-id="@f.Id" target="_blank">Imprimir</a>
                    @if (!f.EstaFirmada)
                    {
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@f.Id">Editar</a>
                        <form asp-action="Firmar" asp-route-id="@f.Id" method="post" class="d-inline"
                              onsubmit="return confirm('¿Firmar la factura @f.Numero? No se podrá modificar luego.');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-success">Firmar</button>
                        </form>
                        <form asp-action="Delete" asp-route-id="@f.Id" method="post" class="d-inline"
                              onsubmit="return confirm('¿Eliminar la factura @f.Numero?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">×</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
